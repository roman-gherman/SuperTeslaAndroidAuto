<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:layout_gravity="center_horizontal"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="24dp">
        <View
            android:layout_gravity="center"
            android:background="@drawable/halo_gradient"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:translationZ="-1dp"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_gravity="center"
            android:id="@+id/startStopButton"
            android:focusable="true"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/buttonDarkBackground"
            app:cardCornerRadius="100dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/service_inactive"
            app:strokeWidth="3dp">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:id="@+id/startStopIcon"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginBottom="8dp"
                    android:src="@drawable/ic_play"
                    app:layout_constraintBottom_toTopOf="@+id/startStopText"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_chainStyle="packed"
                    app:tint="@color/textColorPrimary"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:id="@+id/startStopText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/start"
                    app:layout_constraintBottom_toTopOf="@+id/serviceStatusText"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/startStopIcon"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/textColorSecondary"
                    android:id="@+id/serviceStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/inactive"
                    android:alpha="0.8"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/startStopText"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/homeInstructionsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/cardBackground"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/cardBorder"
        app:strokeWidth="1dp">
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_info_24"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/tesla_blue_primary"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/connection_instructions"
                    android:layout_weight="1"/>
            </LinearLayout>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/textColorSecondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/home_connect_instructions_desc"/>
            <com.google.android.material.button.MaterialButton
                android:textStyle="bold"
                android:textColor="@color/tesla_blue_primary"
                android:id="@+id/btnHomeToGuide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/home_view_guide_button"
                app:cornerRadius="24dp"
                app:strokeColor="@color/tesla_blue_primary"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/demoModeCard"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/cardBackground"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/cardBorder"
        app:strokeWidth="2dp">
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_schedule_24"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/icon"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/demo_mode_title"
                    android:layout_weight="1"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textStyle="bold"
                    android:textColor="@color/tesla_cyan_accent"
                    android:id="@+id/demoTimeRemainingText"
                    android:background="@drawable/bg_rounded_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10:00"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"/>
            </LinearLayout>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/textColorSecondary"
                android:id="@+id/demoModeInfoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/demo_mode_default_description"
                android:lineSpacingExtra="2dp"/>
            <com.google.android.material.button.MaterialButton
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:id="@+id/unlockFullAccessButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/demo_mode_unlock_full"
                app:backgroundTint="@color/tesla_blue_primary"
                app:cornerRadius="24dp"
                style="@style/Widget.Material3.Button"/>
            <com.google.android.material.button.MaterialButton
                android:textColor="@color/tesla_text_secondary"
                android:id="@+id/rearmDemoButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/demo_mode_extend"
                app:icon="@drawable/ic_refresh_24"
                app:iconTint="@color/tesla_text_secondary"
                app:strokeColor="@color/tesla_divider"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/permissionsCard"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@color/cardBackground"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/cardBorder"
        app:strokeWidth="2dp">
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_security_24"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/icon"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/permissions_status"
                    android:layout_weight="1"/>
                <ImageView
                    android:id="@+id/permissionsExpandIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_expand_more_24"
                    android:contentDescription="@string/expand_permissions"
                    android:rotation="0"
                    app:tint="@color/textColorSecondary"/>
            </LinearLayout>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/textColorSecondary"
                android:id="@+id/permissionsStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/checking_permissions"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/permissionsDetailContainer"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>
            <com.google.android.material.button.MaterialButton
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:id="@+id/grantPermissionsButton"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/grant_permissions"
                app:backgroundTint="@color/tesla_blue_primary"
                app:cornerRadius="24dp"
                style="@style/Widget.Material3.Button"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
