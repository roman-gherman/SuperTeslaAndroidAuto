<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?attr/colorSurface"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="24dp">
            <ImageView
                android:id="@+id/statusIcon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp"
                android:src="@drawable/ic_star_24"
                app:tint="#ffc107"/>
            <TextView
                android:textAppearance="?attr/textAppearanceHeadline5"
                android:textColor="?attr/colorOnSurface"
                android:gravity="center"
                android:id="@+id/titleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/choose_taada_premium_plan"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:id="@+id/socialProofContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_star_24"
                    app:tint="#ffc107"/>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_star_24"
                    app:tint="#ffc107"/>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_star_24"
                    app:tint="#ffc107"/>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_star_24"
                    app:tint="#ffc107"/>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_star_24"
                    app:tint="#ffc107"/>
            </LinearLayout>
            <TextView
                android:textAppearance="?attr/textAppearanceCaption"
                android:textStyle="italic"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rejoignez +15 000 conducteurs satisfaits"/>
        </LinearLayout>
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/featuresCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textAppearance="?attr/textAppearanceSubtitle1"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="@string/premium_benefits"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/featureRow1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check_circle_24"
                            android:layout_marginEnd="12dp"
                            app:tint="?attr/colorPrimary"/>
                        <TextView
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/paywall_feature_drive_time"
                            android:layout_weight="1"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/featureRow2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check_circle_24"
                            android:layout_marginEnd="12dp"
                            app:tint="?attr/colorPrimary"/>
                        <TextView
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/feature_full_access"
                            android:layout_weight="1"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/featureRow3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check_circle_24"
                            android:layout_marginEnd="12dp"
                            app:tint="?attr/colorPrimary"/>
                        <TextView
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/feature_priority_support"
                            android:layout_weight="1"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/featureRow4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_check_circle_24"
                            android:layout_marginEnd="12dp"
                            app:tint="?attr/colorPrimary"/>
                        <TextView
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/feature_advanced_config"
                            android:layout_weight="1"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <TextView
            android:textAppearance="?attr/textAppearanceBody1"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            android:id="@+id/descriptionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/subscription_description"
            android:lineSpacingExtra="4dp"/>
        <ProgressBar
            android:layout_gravity="center"
            android:id="@+id/loadingIndicator"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/purchaseOptionsContainer"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/monthlyCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:checkedIcon="@null"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                style="@style/Widget.Material3.CardView.Outlined">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/monthlyCheckIcon"
                        android:visibility="visible"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_radio_button_unchecked_24"
                        android:layout_marginEnd="12dp"
                        app:tint="?attr/colorOutline"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <TextView
                            android:textAppearance="?attr/textAppearanceSubtitle1"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/monthly_subscription"/>
                        <TextView
                            android:textAppearance="?attr/textAppearanceCaption"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:id="@+id/monthlyDescriptionText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/paywall_no_commitment"/>
                    </LinearLayout>
                    <TextView
                        android:textAppearance="?attr/textAppearanceSubtitle1"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:id="@+id/monthlyPriceText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/monthly_price_placeholder"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/annualCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:checkedIcon="@null"
                app:strokeColor="?attr/colorPrimary"
                app:strokeWidth="2dp"
                style="@style/Widget.Material3.CardView.Elevated">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:id="@+id/annualCheckIcon"
                        android:visibility="visible"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check_circle_24"
                        android:layout_marginEnd="16dp"
                        app:tint="?attr/colorPrimary"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp">
                            <TextView
                                android:textAppearance="?attr/textAppearanceSubtitle1"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="@string/annual_subscription"
                                android:layout_weight="1"/>
                            <TextView
                                android:textAppearance="?attr/textAppearanceCaption"
                                android:textStyle="bold"
                                android:textColor="#ffffff"
                                android:id="@+id/annualBadgeText"
                                android:background="@drawable/badge_background"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/paywall_badge_popular"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp">
                            <TextView
                                android:textAppearance="?attr/textAppearanceHeadline6"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary"
                                android:id="@+id/annualPriceText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/annual_price_placeholder"/>
                            <TextView
                                android:textAppearance="?attr/textAppearanceBody2"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:id="@+id/annualStrikethroughText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="29,88€"
                                android:layout_marginStart="8dp"/>
                            <TextView
                                android:textAppearance="?attr/textAppearanceCaption"
                                android:textStyle="bold"
                                android:textColor="#4caf50"
                                android:id="@+id/annualSavingsText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-33%"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                        <TextView
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:id="@+id/annualDescriptionText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/annual_description"/>
                        <TextView
                            android:textAppearance="?attr/textAppearanceCaption"
                            android:textStyle="bold"
                            android:textColor="#4caf50"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/paywall_free_trial_badge"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/lifetimeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:checkedIcon="@null"
                app:strokeColor="#ffc107"
                app:strokeWidth="3dp"
                style="@style/Widget.Material3.CardView.Elevated">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:id="@+id/lifetimeCheckIcon"
                        android:visibility="visible"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_radio_button_unchecked_24"
                        android:layout_marginEnd="16dp"
                        app:tint="?attr/colorOutline"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:textAppearance="?attr/textAppearanceSubtitle1"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="@string/lifetime_access_title"
                                android:layout_weight="1"/>
                            <TextView
                                android:textAppearance="?attr/textAppearanceCaption"
                                android:textStyle="bold"
                                android:textColor="#000000"
                                android:id="@+id/lifetimeBadgeText"
                                android:background="@drawable/badge_background_gold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/paywall_badge_best_value"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:textAppearance="?attr/textAppearanceHeadline4"
                                android:textStyle="bold"
                                android:textColor="#ffc107"
                                android:id="@+id/lifetimePriceText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/lifetime_price_placeholder"/>
                            <TextView
                                android:textAppearance="?attr/textAppearanceBody1"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:id="@+id/lifetimeStrikethroughText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="149,99€"
                                android:layout_marginStart="12dp"/>
                            <TextView
                                android:textAppearance="?attr/textAppearanceSubtitle2"
                                android:textStyle="bold"
                                android:textColor="#4caf50"
                                android:id="@+id/lifetimeDiscountText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-60%"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                        <TextView
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:id="@+id/lifetimeDescriptionText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:text="@string/lifetime_description"/>
                        <TextView
                            android:textAppearance="?attr/textAppearanceCaption"
                            android:textStyle="bold"
                            android:textColor="#ffc107"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/paywall_lifetime_value_1"/>
                        <TextView
                            android:textAppearance="?attr/textAppearanceCaption"
                            android:textStyle="bold"
                            android:textColor="#ffc107"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/paywall_lifetime_value_2"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
        <com.google.android.material.button.MaterialButton
            android:textSize="16sp"
            android:textStyle="bold"
            android:id="@+id/secondaryActionButton"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:text="@string/later"
            android:elevation="4dp"
            app:cornerRadius="24dp"
            style="@style/Widget.Material3.Button"/>
        <TextView
            android:textAppearance="?attr/textAppearanceCaption"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/subscription_legal_text"
            android:lineSpacingExtra="2dp"/>
    </LinearLayout>
</ScrollView>
