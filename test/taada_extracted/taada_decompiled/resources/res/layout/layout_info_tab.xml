<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/aboutDeveloperCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/cardBackground"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/cardBorder"
        app:strokeWidth="2dp">
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_heart_24"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/icon"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dev_info_title"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_code_24"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/icon_code_cyan"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/textColorSecondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/dev_info_body"
                    android:layout_weight="1"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_coffee_24"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/icon_coffee_orange"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/textColorSecondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/dev_info_costs_body"
                    android:layout_weight="1"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_heart_24"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/icon_heart_red"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/textColorSecondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/dev_info_support_body"
                    android:layout_weight="1"/>
            </LinearLayout>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textStyle="bold"
                android:textColor="@color/tesla_cyan_accent"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/dev_info_thank_you"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <TextView
        android:textSize="12sp"
        android:textColor="@color/textColorSecondary"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:id="@+id/versionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/app_version"
        android:alpha="0.6"/>
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:id="@+id/socialLinksContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp">
        <ImageButton
            android:id="@+id/githubButton"
            android:background="@drawable/ripple_rounded_button"
            android:padding="12dp"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_github_24"
            android:scaleType="fitCenter"
            android:contentDescription="GitHub TaaDa"
            android:layout_marginEnd="16dp"
            app:tint="@color/textColorSecondary"/>
        <ImageButton
            android:id="@+id/facebookButton"
            android:background="@drawable/ripple_rounded_button"
            android:padding="12dp"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_facebook_24"
            android:scaleType="fitCenter"
            android:contentDescription="Facebook TaaDa"
            android:layout_marginEnd="16dp"
            app:tint="@color/textColorSecondary"/>
        <ImageButton
            android:id="@+id/linkedinButton"
            android:background="@drawable/ripple_rounded_button"
            android:padding="12dp"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_linkedin_24"
            android:scaleType="fitCenter"
            android:contentDescription="LinkedIn TaaDa"
            android:layout_marginEnd="16dp"
            app:tint="@color/textColorSecondary"/>
        <ImageButton
            android:id="@+id/youtubeButton"
            android:background="@drawable/ripple_rounded_button"
            android:padding="12dp"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_youtube_24"
            android:scaleType="fitCenter"
            android:contentDescription="YouTube TaaDa"
            app:tint="@color/textColorSecondary"/>
    </LinearLayout>
</LinearLayout>
