<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory
        android:icon="@drawable/ic_language_24"
        android:title="@string/pref_cat_language"
        android:key="language_category"
        app:iconSpaceReserved="true">
        <ListPreference
            android:persistent="true"
            android:enabled="true"
            android:entries="@array/language_entries"
            android:title="@string/pref_language"
            android:key="app_language"
            android:summary="@string/pref_language_summary"
            android:defaultValue="auto"
            android:entryValues="@array/language_values"
            app:iconSpaceReserved="true"
            app:singleLineTitle="false"/>
    </PreferenceCategory>
    <PreferenceCategory
        android:icon="@drawable/ic_bluetooth_24"
        android:title="@string/bluetooth"
        android:key="bluetooth_category"
        app:iconSpaceReserved="true">
        <fr.sd.taada.helpers.EmptyListPreference
            android:persistent="true"
            android:enabled="true"
            android:title="@string/settings_bluetooth_selected_bluetooth_devices_title"
            android:key="selected_bluetooth_devices"
            android:summary="@string/settings_bluetooth_selected_bluetooth_devices_description"
            app:iconSpaceReserved="true"
            app:singleLineTitle="false"/>
    </PreferenceCategory>
    <PreferenceCategory
        android:icon="@drawable/ic_baseline_computer_24"
        android:title="@string/options"
        android:key="options_category"
        app:iconSpaceReserved="true">
        <SeekBarPreference
            android:enabled="true"
            android:max="300"
            android:title="@string/ui_size"
            android:key="dpi"
            android:summary="@string/ui_size_description"
            android:defaultValue="120"
            app:min="100"
            app:showSeekBarValue="true"/>
        <ListPreference
            android:persistent="true"
            android:enabled="true"
            android:title="@string/select_your_resolution"
            android:key="resolution"
            android:summary="%s"
            android:defaultValue="1"
            android:entryValues="@array/resValues"
            app:entries="@array/resArray"
            app:iconSpaceReserved="true"
            app:singleLineTitle="false"/>
        <SwitchPreferenceCompat
            android:persistent="true"
            android:enabled="true"
            android:title="@string/usevpn"
            android:key="usevpn"
            android:summary="@string/novpn"
            android:defaultValue="true"
            app:iconSpaceReserved="true"
            app:singleLineTitle="false"/>
        <SwitchPreferenceCompat
            android:persistent="true"
            android:enabled="true"
            android:title="@string/useBT"
            android:key="useBT"
            android:summary="@string/useBT_desc"
            android:defaultValue="true"
            app:iconSpaceReserved="true"
            app:singleLineTitle="false"/>
        <SwitchPreferenceCompat
            android:persistent="true"
            android:enabled="true"
            android:title="@string/showdebug"
            android:key="showdebug"
            android:defaultValue="false"
            app:iconSpaceReserved="true"
            app:singleLineTitle="false"/>
    </PreferenceCategory>
    <PreferenceCategory
        android:title="@string/status"
        android:key="status_category"
        app:iconSpaceReserved="true">
        <Preference
            android:persistent="false"
            android:enabled="true"
            android:key="permissions_status"
            app:iconSpaceReserved="true"/>
        <Preference
            android:persistent="true"
            android:enabled="true"
            android:title="@string/settings_advanced_options_start_service_manually_title"
            android:key="start_service_manually"
            app:iconSpaceReserved="true"/>
    </PreferenceCategory>
    <PreferenceCategory
        android:title="�� Diagnostic Mémoire"
        android:key="memory_diagnostic_category"
        app:iconSpaceReserved="true">
        <Preference
            android:persistent="false"
            android:enabled="true"
            android:title="�� Diagnostic Mémoire"
            android:key="memory_diagnostic"
            android:summary="Vérifie l&apos;état actuel de la mémoire"
            app:iconSpaceReserved="true"/>
        <Preference
            android:persistent="false"
            android:enabled="true"
            android:title="⚡ Stress Test Mémoire"
            android:key="memory_stress_test"
            android:summary="Test intensif de gestion mémoire (⚠️ Peut ralentir l&apos;appareil)"
            app:iconSpaceReserved="true"/>
        <Preference
            android:persistent="false"
            android:enabled="true"
            android:title="�� Nettoyage Mémoire"
            android:key="memory_cleanup"
            android:summary="Force le nettoyage de la mémoire"
            app:iconSpaceReserved="true"/>
    </PreferenceCategory>
    <PreferenceCategory>
        <Preference
            android:persistent="true"
            android:enabled="true"
            android:title="@string/requierments"
            android:key="none"
            android:summary="@string/vpn_service"
            app:iconSpaceReserved="true"/>
    </PreferenceCategory>
    <PreferenceCategory>
        <Preference
            android:persistent="true"
            android:enabled="true"
            android:key="none_3"
            android:summary="@string/navigate_to"
            android:textAlignment="center"
            app:iconSpaceReserved="true"/>
    </PreferenceCategory>
</PreferenceScreen>
