<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/zoomCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    app:cardBackgroundColor="@color/cardBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/cardBorder"
    app:strokeWidth="2dp">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_interface_size_24"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/icon"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/zoom_control_title"/>
            </LinearLayout>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/tesla_text_primary"
                android:gravity="center"
                android:id="@+id/zoomValueText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/zoom_default_value"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.google.android.material.button.MaterialButton
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/tesla_cyan_accent"
                    android:gravity="center"
                    android:id="@+id/zoomDecreaseButton"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="−"
                    android:contentDescription="@string/zoom_decrease"
                    app:backgroundTint="@color/buttonDarkBackground"
                    app:cornerRadius="24dp"
                    app:strokeColor="@color/tesla_cyan_accent"
                    app:strokeWidth="2dp"
                    style="@style/Widget.Material3.Button.IconButton"/>
                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1">
                    <androidx.appcompat.widget.AppCompatSeekBar
                        android:id="@+id/zoomSeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:max="20"
                        android:progress="2"
                        android:splitTrack="false"
                        android:progressTint="@color/tesla_cyan_accent"
                        android:progressBackgroundTint="@color/textColorSecondary"
                        android:thumbTint="@color/tesla_cyan_accent"/>
                    <ImageView
                        android:id="@+id/recommendedIndicator"
                        android:visibility="invisible"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:src="@drawable/ic_recommended_indicator"
                        android:layout_centerVertical="true"
                        android:contentDescription="@string/recommended_value"/>
                </RelativeLayout>
                <com.google.android.material.button.MaterialButton
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/tesla_cyan_accent"
                    android:gravity="center"
                    android:id="@+id/zoomIncreaseButton"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="+"
                    android:contentDescription="@string/zoom_increase"
                    app:backgroundTint="@color/buttonDarkBackground"
                    app:cornerRadius="24dp"
                    app:strokeColor="@color/tesla_cyan_accent"
                    app:strokeWidth="2dp"
                    style="@style/Widget.Material3.Button.IconButton"/>
            </LinearLayout>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="@color/textColorSecondary"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/zoom_control_description"
                android:alpha="0.8"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textStyle="italic"
                android:textColor="@android:color/holo_green_dark"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/recommended_size_hint"
                android:alpha="0.9"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
