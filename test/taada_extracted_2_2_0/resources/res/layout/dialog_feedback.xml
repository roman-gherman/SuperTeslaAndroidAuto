<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/cardBackground"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageButton
        android:id="@+id/closeButton"
        android:background="@drawable/ripple_rounded_small_button"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_cancel_24"
        android:contentDescription="@string/close_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/textColorSecondary"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/iconContainer"
        android:background="@drawable/rounded_background"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="@color/tesla_cyan_accent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/closeButton">
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_feedback_24"
            app:tint="@android:color/white"/>
    </LinearLayout>
    <TextView
        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
        android:textStyle="bold"
        android:textColor="@color/textColorPrimary"
        android:gravity="center"
        android:id="@+id/titleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/feedback_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iconContainer"/>
    <TextView
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
        android:textColor="@color/textColorSecondary"
        android:gravity="center"
        android:id="@+id/subtitleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/feedback_subtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/titleText"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/infoLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/subtitleText">
        <TextView
            android:textSize="14sp"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:text="��"
            android:layout_marginEnd="8dp"/>
        <TextView
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/textColorSecondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/feedback_info_message"
            android:layout_weight="1"/>
    </LinearLayout>
    <TextView
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="@color/textColorSecondary"
        android:id="@+id/descriptionText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/feedback_description"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/infoLayout"/>
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/feedbackInputLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="@string/feedback_hint"
        app:boxBackgroundColor="@color/cardBackgroundVariant"
        app:boxBackgroundMode="filled"
        app:boxCornerRadiusBottomEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusTopStart="8dp"
        app:boxStrokeColor="@color/tesla_cyan_accent"
        app:hintTextColor="@color/textColorSecondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/descriptionText">
        <com.google.android.material.textfield.TextInputEditText
            android:textColor="@color/textColorPrimary"
            android:textColorHint="@color/textColorSecondary"
            android:gravity="top"
            android:id="@+id/feedbackEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lines="4"
            android:minLines="4"
            android:inputType="textMultiLine"/>
    </com.google.android.material.textfield.TextInputLayout>
    <com.google.android.material.button.MaterialButton
        android:textColor="@android:color/white"
        android:id="@+id/sendFeedbackButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/feedback_send_button"
        app:backgroundTint="@color/tesla_cyan_accent"
        app:cornerRadius="8dp"
        app:icon="@drawable/ic_send_24"
        app:iconTint="@android:color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/feedbackInputLayout"/>
    <com.google.android.material.button.MaterialButton
        android:textColor="@color/textColorSecondary"
        android:id="@+id/laterButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/feedback_later_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/sendFeedbackButton"
        style="@style/Widget.Material3.Button.TextButton"/>
</androidx.constraintlayout.widget.ConstraintLayout>
