<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="@string/tutorial_title"/>
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        app:cardBackgroundColor="#212121"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">
        <ImageView
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:src="@drawable/guide_infographic_timeline"
            android:scaleType="fitCenter"
            android:contentDescription="Setup Process Infographic"/>
    </com.google.android.material.card.MaterialCardView>
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@color/tesla_bg_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/cardBorder"
        app:strokeWidth="1dp">
        <LinearLayout
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                android:textStyle="bold"
                android:textColor="@color/tesla_blue_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/tutorial_first_launch"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textStyle="bold"
                    android:textColor="@color/tesla_blue_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. "
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/tutorial_check_permissions"
                    android:layout_weight="1"/>
            </LinearLayout>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/textColorSecondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:text="@string/tutorial_check_permissions_desc"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textStyle="bold"
                    android:textColor="@color/tesla_blue_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. "
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/tutorial_enable_connections"
                    android:layout_weight="1"/>
            </LinearLayout>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/textColorSecondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:text="@string/tutorial_enable_connections_desc"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textStyle="bold"
                    android:textColor="@color/tesla_blue_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3. "
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/tutorial_launch_aa"
                    android:layout_weight="1"/>
            </LinearLayout>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/textColorSecondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:text="@string/tutorial_launch_aa_desc"/>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textStyle="bold"
                    android:textColor="@color/tesla_blue_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4. "
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/tutorial_open_car"
                    android:layout_weight="1"/>
            </LinearLayout>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/textColorSecondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/tutorial_open_car_desc_part1"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                android:textStyle="bold"
                android:textColor="@color/tesla_blue_primary"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/tutorial_open_car_url"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/textColorSecondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tutorial_open_car_desc_part2"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@color/tesla_bg_surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/cardBorder"
        app:strokeWidth="1dp">
        <LinearLayout
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
                android:textStyle="bold"
                android:textColor="@color/tesla_blue_primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/tutorial_tips"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textStyle="bold"
                android:textColor="@color/textColorPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tutorial_wifi_tip"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/textColorSecondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/tutorial_wifi_tip_desc"/>
            <com.google.android.material.button.MaterialButton
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:id="@+id/guideWifiButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"
                android:text="@string/tutorial_wifi_settings"
                app:backgroundTint="@color/tesla_blue_primary"
                app:cornerRadius="24dp"
                style="@style/Widget.Material3.Button"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textStyle="bold"
                android:textColor="@color/textColorPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tutorial_battery_tip"/>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/textColorSecondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/tutorial_battery_tip_desc"/>
            <com.google.android.material.button.MaterialButton
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:id="@+id/guideBatteryButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/tutorial_battery_settings"
                app:backgroundTint="@color/tesla_blue_primary"
                app:cornerRadius="24dp"
                style="@style/Widget.Material3.Button"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <TextView
        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
        android:textStyle="bold"
        android:textColor="@color/textColorPrimary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/tutorial_next_launches"/>
    <TextView
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="@color/textColorSecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp"
        android:text="@string/tutorial_next_launches_desc"/>
</LinearLayout>
