<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginLeft="16dp"
    android:layout_marginRight="16dp">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/ripple_rounded_button"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/log_collection"/>
            <TextView
                android:textSize="14sp"
                android:id="@+id/text_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/log_status_disabled"/>
        </LinearLayout>
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_logging"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"/>
    </LinearLayout>
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/tesla_cyan_accent"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:strokeColor="@color/cardBorder"
        app:strokeWidth="2dp">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_warning_24"
                android:layout_marginEnd="12dp"
                app:tint="@android:color/white"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@android:color/white"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/log_performance_warning"
                android:layout_weight="1"
                android:lineSpacingExtra="2dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">
        <ImageButton
            android:enabled="false"
            android:id="@+id/button_refresh"
            android:background="@drawable/ripple_rounded_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_sync_24"
            android:contentDescription="@string/refresh"
            android:layout_marginEnd="8dp"
            app:tint="@android:color/white"/>
        <ImageButton
            android:enabled="false"
            android:id="@+id/button_copy"
            android:background="@drawable/ripple_rounded_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_copy_24"
            android:contentDescription="@string/copy"
            android:layout_marginEnd="8dp"
            app:tint="@android:color/white"/>
        <ImageButton
            android:enabled="false"
            android:id="@+id/button_share"
            android:background="@drawable/ripple_rounded_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_share_24"
            android:contentDescription="@string/share"
            android:layout_marginEnd="8dp"
            app:tint="@android:color/white"/>
        <ImageButton
            android:enabled="false"
            android:id="@+id/button_clear"
            android:background="@drawable/ripple_rounded_button"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_delete_24"
            android:contentDescription="@string/clear"
            app:tint="@android:color/white"/>
    </LinearLayout>
    <TextView
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/log_files"/>
    <ScrollView
        android:background="@drawable/ripple_rounded_button"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        android:layout_weight="0.3">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/layout_log_files"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </ScrollView>
    <TextView
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="@string/log_content"/>
    <ScrollView
        android:id="@+id/scroll_view_logs"
        android:background="@drawable/ripple_rounded_button"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.7">
        <TextView
            android:textSize="12sp"
            android:id="@+id/text_log_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/log_collection_disabled_message"
            android:scrollHorizontally="true"
            android:singleLine="false"
            android:textIsSelectable="true"
            android:fontFamily="monospace"/>
    </ScrollView>
</LinearLayout>
