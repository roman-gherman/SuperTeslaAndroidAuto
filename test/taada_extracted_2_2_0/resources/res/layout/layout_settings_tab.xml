<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bluetoothCard"
        android:focusable="true"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="@color/cardBackground"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/cardBorder"
        app:strokeWidth="2dp">
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_bluetooth_24"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/icon"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bluetooth_devices"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/holo_orange_light"
                    android:id="@+id/bluetoothExperimentalLabel"
                    android:visibility="visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/resolution_experimental"
                    android:layout_marginStart="8dp"/>
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>
                <ImageButton
                    android:id="@+id/bluetoothInfoButton"
                    android:background="@drawable/ripple_rounded_small_button"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_info_outline_16"
                    android:scaleType="centerInside"
                    android:contentDescription="Bluetooth information"
                    app:tint="@color/textColorSecondary"/>
            </LinearLayout>
            <TextView
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/textColorSecondary"
                android:ellipsize="end"
                android:id="@+id/btStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/no_device_selected"
                android:maxLines="2"/>
            <TextView
                android:textStyle="italic"
                android:textColor="@color/tesla_blue_accent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.8"/>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/android16WarningContainer"
                android:background="@drawable/rounded_warning_background"
                android:padding="8dp"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="@color/textColorPrimary"
                    android:id="@+id/android16WarningShizukuText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/android_16_hotspot_warning_shizuku"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textStyle="bold"
                    android:textColor="@color/tesla_blue_accent"
                    android:id="@+id/android16LinkText"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/android_16_hotspot_link_text"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="@color/textColorPrimary"
                    android:id="@+id/android16WarningSamsungText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/android_16_hotspot_warning_samsung"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <include
        android:id="@+id/resolutionControlLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        layout="@layout/resolution_control_layout"/>
    <include
        android:id="@+id/zoomControlLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        layout="@layout/zoom_control_layout"/>
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/steeringWheelCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/cardBackground"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/cardBorder"
        app:strokeWidth="2dp">
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_steering_wheel_24"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/icon"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/textColorPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/steering_wheel_title"/>
            </LinearLayout>
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/steeringWheelToggleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:selectionRequired="true"
                app:singleSelection="true">
                <com.google.android.material.button.MaterialButton
                    android:textColor="@color/tesla_cyan_accent"
                    android:id="@+id/steeringWheelLeft"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/steering_wheel_left"
                    android:layout_weight="1"
                    app:icon="@drawable/ic_steering_wheel_left"
                    app:iconGravity="textStart"
                    app:iconTint="@color/tesla_cyan_accent"
                    app:strokeColor="@color/tesla_cyan_accent"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>
                <com.google.android.material.button.MaterialButton
                    android:textColor="@color/tesla_cyan_accent"
                    android:id="@+id/steeringWheelRight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/steering_wheel_right"
                    android:layout_weight="1"
                    app:icon="@drawable/ic_steering_wheel_right"
                    app:iconGravity="textStart"
                    app:iconTint="@color/tesla_cyan_accent"
                    app:strokeColor="@color/tesla_cyan_accent"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
