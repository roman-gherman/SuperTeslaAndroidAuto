<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textAppearance="@style/Tesla.Text.Body.Medium"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/tesla_text_primary"
            android:id="@+id/badgeText"
            android:background="@drawable/bg_tesla_card"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BEST VALUE"
            android:layout_marginEnd="8dp"
            android:backgroundTint="@color/tesla_blue_primary"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:id="@+id/planTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Annual"
            app:layout_constraintBottom_toTopOf="@+id/planPrice"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/Tesla.Text.Title.Medium"/>
        <TextView
            android:textStyle="bold"
            android:id="@+id/planPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="€49.99"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/planTitle"
            style="@style/Tesla.Text.Title.Large"/>
        <TextView
            android:id="@+id/planPeriod"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="/year"
            android:layout_marginStart="4dp"
            app:layout_constraintBaseline_toBaselineOf="@+id/planPrice"
            app:layout_constraintStart_toEndOf="@+id/planPrice"
            style="@style/Tesla.Text.Body.Medium"/>
        <TextView
            android:id="@+id/planSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="7 Days Free Trial"
            app:layout_constraintEnd_toStartOf="@+id/selectionIndicator"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/planPrice"
            style="@style/Tesla.Text.Body.Medium"/>
        <ImageView
            android:id="@+id/selectionIndicator"
            android:visibility="invisible"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_check_circle_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/tesla_blue_primary"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</merge>
